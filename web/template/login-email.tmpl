<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>Login to Nakama</title>
	</head>
	<body style="margin: 0; padding: 0; background-color: #f5f5f5; color: #111111; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">
		<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse: collapse; width: 100%; background-color: #f5f5f5;">
			<tr>
				<td align="center" style="padding: 24px 16px;">
					<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse: collapse; width: 100%; max-width: 600px; background-color: #ffffff; border: 1px solid #e5e5e5; border-radius: 12px;">
						<tr>
							<td style="padding: 32px 24px;">
								<h1 style="margin: 0 0 16px; font-size: 28px; line-height: 1.2; font-weight: 700; color: #111111;">Login to Nakama</h1>
								<p style="margin: 0 0 16px; font-size: 16px; line-height: 1.6; color: #444444;">Use the link below to login to your Nakama account.</p>
								<p style="margin: 0 0 16px;">
									<a href="{{ .MagicLink }}" style="display: inline-block; padding: 12px 18px; background-color: #111111; color: #ffffff; text-decoration: none; font-size: 16px; font-weight: 600; border-radius: 999px;">Login to Nakama</a>
								</p>
								<p style="margin: 0 0 24px; font-size: 14px; line-height: 1.6; color: #666666;">This link expires in {{ humanDuration .TTL }}.</p>
								<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse: collapse; width: 100%; background-color: #fafafa; border: 1px solid #e5e5e5; border-radius: 8px;">
									<tr>
										<td style="padding: 20px 18px;">
											<h2 style="margin: 0 0 12px; font-size: 18px; line-height: 1.3; font-weight: 600; color: #111111;">Verification code</h2>
											<p style="margin: 0 0 12px; font-size: 15px; line-height: 1.6; color: #444444;">Another option is to copy and paste this verification code in the app:</p>
											<p style="margin: 0;"><code style="display: inline-block; padding: 10px 12px; background-color: #f0f0f0; border-radius: 6px; font-size: 16px; line-height: 1; color: #111111; font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; letter-spacing: 0.08em;">{{ .Code }}</code></p>
										</td>
									</tr>
								</table>
								<p style="margin: 24px 0 0; font-size: 14px; line-height: 1.6; color: #666666;">If you did not request this email, you can ignore it.</p>
							</td>
						</tr>
					</table>
				</td>
			</tr>
		</table>
	</body>
</html>
