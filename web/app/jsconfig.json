{
    "compilerOptions": {
        "allowJs": true,
        "checkJs": true,
        "module": "ESNext",
        "target": "ESNext",
        "moduleResolution": "Bundler",
        "lib": [
            "ESNext",
            "DOM",
            "DOM.Iterable"
        ]
    },
    "exclude": [
        "node_modules"
    ]
}
